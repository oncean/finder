# 运行环境
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fengxiangbiao
DB_USER=app
DB_PASSWORD=dev123456

# JWT 密钥
JWT_SECRET=fengxiangbiao-secret-key-2024

# 可选：Snowflake 机器号。微信云托管多实例共享环境变量时不要配置，默认会从 INSTANCE_ID / HOSTNAME 自动派生。
# SNOWFLAKE_WORKER_ID=1

# 微信小程序配置
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret

# 文件上传目录（用户上传文件存放路径）
UPLOAD_DIR=./uploads

# 用户上传文件访问 Base URL（数据库存储的完整 URL 前缀）
UPLOAD_BASE_URL=http://localhost:3000
