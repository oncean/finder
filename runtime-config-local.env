# ============================================
# Finder 后端 - 本地开发环境配置
# 复制此文件为 .env.development 后填入实际值
# ============================================

# ---------- 运行环境 ----------
NODE_ENV=development
PORT=3000

# ---------- 数据库 (PostgreSQL) ----------
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finder
DB_USER=postgres
DB_PASSWORD=postgres

# ---------- 数据库 (MySQL，切换时注释掉 PostgreSQL 配置) ----------
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=finder
# DB_USER=root
# DB_PASSWORD=root

# ---------- JWT ----------
JWT_SECRET=fengxiangbiao-secret-key-2024

# ---------- 微信小程序 ----------
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# ---------- 微信云托管 ----------
CLOUD_ENV_ID=prod-d0go4c43b289bc3bb

# ---------- 文件存储 (local / cloud) ----------
STORAGE_MODE=local
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:3000

# ---------- 本地开发用模拟微信用户 ----------
DEV_OPENID=mock_openid_developer
DEV_UNIONID=mock_unionid_developer

# ---------- Snowflake ID ----------
# SNOWFLAKE_WORKER_ID=1

# ---------- HTTPS ----------
NODE_TLS_REJECT_UNAUTHORIZED=0
