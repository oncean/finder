.comment-detail-page {
  background: #fff;
  min-height: 100vh;
  padding-bottom: 150rpx;
}

.top-nav {
  height: 176rpx;
  padding: 76rpx 30rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  background: #fff;
  position: relative;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
}

.menu-pill {
  width: 130rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: rgba(246, 246, 246, 0.95);
  display: flex;
  align-items: center;
  justify-content: space-around;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.circle-dot {
  font-size: 35rpx;
}

.gallery-section {
  width: 100%;
}

.gallery-swiper {
  width: 100%;
  height: 506rpx;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.shop-cover {
  width: 100%;
  height: 506rpx;
  display: block;
}

.comment-info-section {
  background: #fff;
  padding: 28rpx 30rpx 24rpx;
  border-bottom: 12rpx solid #f5f5f5;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14rpx;
  gap: 16rpx;
}

.comment-title {
  font-size: 31rpx;
  line-height: 1.25;
  color: #111827;
  flex: 1;
}

.rank-pill {
  background: linear-gradient(90deg, #dcfce7 0%, #94f2d4 100%);
  color: #196b3f;
  font-size: 21rpx;
  font-weight: 800;
  padding: 7rpx 16rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.comment-content {
  display: block;
  color: #333;
  font-size: 27rpx;
  line-height: 1.45;
  margin-bottom: 8rpx;
}

.shop-desc {
  display: block;
  color: #8c8c8c;
  font-size: 27rpx;
  line-height: 1.45;
}

.detail-section {
  padding: 28rpx 30rpx 26rpx;
  background: #fff;
}

.stats-row {
  display: flex;
  align-items: center;
  padding-bottom: 22rpx;
}

.reviewer-avatars {
  display: flex;
  align-items: center;
}

.reviewer-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.reviewer-avatar.overlap {
  margin-left: -16rpx;
}

.review-count {
  margin-left: auto;
  display: flex;
  align-items: baseline;
}

.count-num {
  color: #a3e635;
  font-size: 58rpx;
  font-weight: 900;
  margin-right: 5rpx;
}

.count-label {
  color: #333;
  font-size: 20rpx;
  font-weight: 900;
}

.row-arrow {
  color: #c7c7c7;
  font-size: 42rpx;
  margin-left: 12rpx;
}

.info-row {
  height: 50rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.row-icon {
  width: 44rpx;
  font-size: 28rpx;
}
.dingwei-pin{
  width: 20rpx;
  margin-right: 15rpx;
  height: 20rpx;
}

.clock {
  color: #9bd625;
}

.pin {
  color: #111827;
}

.row-text {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.ai-summary-section {
  margin: 18rpx 0 24rpx;
}

.shop-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.shop-footer .stats-row {
  display: flex;
  align-items: center;
  min-width: 0;
  padding-bottom: 0;
}

.shop-footer .tester-text {
  margin-left: 14rpx;
  color: #9ca3af;
  font-size: 23rpx;
}

.shop-footer .view-btn {
  min-width: 106rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #020617;
  color: #a3e635;
  font-size: 20rpx;
  font-weight: 800;
  font-style: italic;
}

.consume-section {
  padding: 0rpx 20rpx 10rpx;
  background: #fff;
}

.consume-card {
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  height: 200rpx;
}

.consume-card--text {
  background: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consume-receipt {
  width: 100%;
  height: 100%;
}

.consume-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.consume-cert {
  color: #fff;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
  margin-right: 20rpx;
}

.consume-amount-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 900;
}

.recommend-section {
  padding: 28rpx 0 40rpx;
  background: #fff;
}

.recommend-section .section-title {
  padding: 0 30rpx;
}

.recommend-scroll {
  width: 100%;
}

.recommend-list {
  display: flex;
  padding: 0 30rpx;
  gap: 16rpx;
}

.recommend-card {
  flex-shrink: 0;
  width: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(31, 41, 55, 0.06);
}

.recommend-cover-wrap {
  position: relative;
  width: 180rpx;
  height: 135rpx;
  overflow: hidden;
  border-radius: 12rpx;
}

.recommend-cover {
  width: 180rpx;
  height: 135rpx;
  display: block;
}

.recommend-info {
  padding: 10rpx;
}

.recommend-title {
  font-size: 22rpx;
  color: #111827;
  font-weight: 600;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.recommend-review-bar {
  position: absolute;
  bottom: 0rpx;
  left: 0rpx;
  right: 0rpx;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  height: 35rpx;
  padding: 0 10rpx;
  line-height: 25rpx;
  border-radius: 0 0 12rpx 12rpx;
}

.recommend-review-text {
  color: #fff;
  font-size: 18rpx;
  font-weight: 500;
}

.section-title {
  font-size: 25rpx;
  font-weight: 900;
  margin-bottom: 20rpx;
  color: #111827;
}

.review-card {
  background: #fff;
  border-radius: 18rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(31, 41, 55, 0.08);
  border: 1rpx solid #f1f5f9;
}

.feed-head {
  display: flex;
  padding: 24rpx 24rpx 18rpx;
  gap: 14rpx;
}

.author-avatar {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.head-main {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feed-title {
  flex: 1;
  min-width: 0;
  color: #1f2933;
  font-size: 29rpx;
  line-height: 1.3;
}

.rating-text {
  color: #84cc16;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.feed-desc {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.45;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  padding: 0 24rpx 24rpx;
}

.food-image {
  width: 100%;
  height: 186rpx;
  border-radius: 8rpx;
}

.empty-reviews {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 27rpx;
  color: #999;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0rpx 30rpx 22rpx;
  box-sizing: border-box;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.share-btn {
  width: 110rpx;
  color: #111827;
  font-size: 23rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-icon {
  width: 38rpx;
  height: 38rpx;
  line-height: 34rpx;
  text-align: center;
  color: #9bd625;
  border: 3rpx solid #9bd625;
  border-radius: 50%;
  font-size: 25rpx;
  margin-bottom: 2rpx;
}

.nav-btn {
  flex: 1;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 999rpx;
  background: #181818;
  color: #a3e635;
  text-align: center;
  font-size: 31rpx;
  font-weight: 900;
  font-style: italic;
}
