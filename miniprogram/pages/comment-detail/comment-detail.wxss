.comment-detail-page {
  background: #fff;
  min-height: 100vh;
  padding-bottom: 150rpx;
}

.top-nav {
  height: 176rpx;
  padding: 76rpx 30rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  background: #fff;
  position: relative;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
}

.menu-pill {
  width: 130rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: rgba(246, 246, 246, 0.95);
  display: flex;
  align-items: center;
  justify-content: space-around;
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.circle-dot {
  font-size: 35rpx;
}

.shop-cover {
  width: 100%;
  height: 506rpx;
  display: block;
}

.shop-info-section {
  background: #fff;
  padding: 28rpx 30rpx 24rpx;
  border-bottom: 12rpx solid #f5f5f5;
}

.shop-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14rpx;
  gap: 16rpx;
}

.shop-name {
  font-size: 31rpx;
  line-height: 1.25;
  color: #111827;
  flex: 1;
}

.rank-pill {
  background: linear-gradient(90deg, #dcfce7 0%, #94f2d4 100%);
  color: #196b3f;
  font-size: 21rpx;
  font-weight: 800;
  padding: 7rpx 16rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.shop-desc {
  display: block;
  color: #8c8c8c;
  font-size: 27rpx;
  line-height: 1.45;
}

.detail-section {
  padding: 28rpx 30rpx 26rpx;
  background: #fff;
}

.tester-row {
  display: flex;
  align-items: center;
  padding-bottom: 22rpx;
}

.tester-avatars {
  display: flex;
  margin-right: auto;
}

.tester-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.tester-avatar.overlap {
  margin-left: -16rpx;
}

.tester-count {
  margin-left: auto;
  display: flex;
  align-items: baseline;
}

.count-num {
  color: #a3e635;
  font-size: 48rpx;
  font-weight: 900;
  margin-right: 5rpx;
}

.count-label {
  color: #333;
  font-size: 26rpx;
}

.row-arrow {
  color: #c7c7c7;
  font-size: 42rpx;
  margin-left: 10rpx;
}

.info-row {
  height: 50rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.row-icon {
  width: 44rpx;
  font-size: 28rpx;
}
.dingwei-pin{
  width: 20rpx;
  margin-right: 15rpx;
  height: 20rpx;
}

.clock {
  color: #9bd625;
}

.pin {
  color: #111827;
}

.row-text {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.ai-summary-section {
  margin: 18rpx 0 24rpx;
}

.shop-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.shop-footer .tester-row {
  display: flex;
  align-items: center;
  min-width: 0;
  padding-bottom: 0;
}

.shop-footer .tester-text {
  margin-left: 14rpx;
  color: #9ca3af;
  font-size: 23rpx;
}

.shop-footer .view-btn {
  min-width: 106rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #020617;
  color: #a3e635;
  font-size: 20rpx;
  font-weight: 800;
  font-style: italic;
}

.pay-record {
  width: 100%;
  height: 208rpx;
  border-radius: 8rpx;
  display: block;
}

.recommend-section {
  padding: 28rpx 0 28rpx 30rpx;
  background: #fff;
}

.section-title {
  font-size: 29rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  color: #111827;
}

.recommend-scroll {
  white-space: nowrap;
}

.recommend-list {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 30rpx;
}

.recommend-item {
  width: 132rpx;
}

.reco-cover-wrap {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.reco-cover {
  width: 100%;
  height: 100%;
}

.reco-count {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 6rpx 0;
  text-align: center;
  color: #fff;
  font-size: 19rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.55));
}

.reco-name {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 132rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 18rpx 30rpx 22rpx;
  box-sizing: border-box;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.share-btn {
  width: 110rpx;
  color: #111827;
  font-size: 23rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-icon {
  width: 38rpx;
  height: 38rpx;
  line-height: 34rpx;
  text-align: center;
  color: #9bd625;
  border: 3rpx solid #9bd625;
  border-radius: 50%;
  font-size: 25rpx;
  margin-bottom: 2rpx;
}

.nav-btn {
  flex: 1;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 999rpx;
  background: #181818;
  color: #a3e635;
  text-align: center;
  font-size: 31rpx;
  font-weight: 900;
  font-style: italic;
}
