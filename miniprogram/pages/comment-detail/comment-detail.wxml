<view class="comment-detail-page">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && shop.id}}">
    <view class="top-nav">
      <view class="back-btn" bindtap="onBack"><image class="back-icon" src="/static/icons/return.svg" mode="aspectFit" /></view>
      <text class="nav-title">详情</text>
    </view>

    <view class="gallery-section" wx:if="{{galleryImages.length}}">
      <swiper class="gallery-swiper" indicator-dots autoplay circular>
        <swiper-item wx:for="{{galleryImages}}" wx:key="index">
          <image class="gallery-image" src="{{item}}" mode="aspectFill" bindtap="onPreviewImage" data-url="{{item}}" data-images="{{galleryImages}}" />
        </swiper-item>
      </swiper>
    </view>

    <view class="comment-info-section">
      <view class="comment-header">
        <text class="comment-title text-bold">{{comment.title || shop.name}}</text>
        <text class="rank-pill" wx:if="{{comment.rankText}}">{{comment.rankText}}</text>
      </view>
      <text class="comment-content" wx:if="{{comment.content}}">{{comment.content}}</text>
      <text class="shop-desc" wx:elif="{{shop.subtitle}}">{{shop.subtitle}}</text>
    </view>

    <view class="detail-section">
      <view class="stats-row" wx:if="{{shop.testerCount || shop.reviewCount}}">
        <view class="reviewer-avatars" wx:if="{{shop.commentAvatars && shop.commentAvatars.length}}">
          <image class="reviewer-avatar {{index > 0 ? 'overlap' : ''}}" wx:for="{{shop.commentAvatars}}" wx:key="index" src="{{item}}" mode="aspectFill" />
        </view>
        <view class="review-count">
          <text class="count-num">{{shop.testerCount || shop.reviewCount}}</text>
          <text class="count-label"> 测评过</text>
        </view>
        <text class="row-arrow">›</text>
      </view>

      <view class="info-row" wx:if="{{shop.businessHours}}">
        <text class="row-icon clock">◷</text>
        <text class="row-text">{{shop.businessHours}}</text>
      </view>

      <view class="info-row" bindtap="onNavigate" wx:if="{{shop.address}}">
        <image class="dingwei-pin" src="/static/icons/dingwei-white.svg" mode="aspectFit" />
        <text class="row-text">{{shop.address}}</text>
      </view>

      <ai-summary summary="{{shop.summaryTags}}" wx:if="{{shop.summaryTags}}"/>
    </view>

    <view class="consume-section" wx:if="{{comment.consumeRecord && comment.consumeRecord.image}}">
      <view class="consume-card" bindtap="onPreviewImage" data-url="{{comment.consumeRecord.image}}" data-images="{{[comment.consumeRecord.image]}}">
        <image class="consume-receipt" src="{{comment.consumeRecord.image}}" mode="aspectFill" />
        <view class="consume-overlay">
          <view class="consume-overlay-logo">
            <image class="logo-img" src="/static/images/YOWEI_LOGO.png" mode="aspectFit" />
            <text class="logo-text">打卡认证</text>
          </view>
          <text class="consume-cert">查看</text>
        </view>
      </view>
    </view>

    <view class="recommend-section" wx:if="{{shop.recommendations && shop.recommendations.length}}">
      <view class="section-title">相关美食/景点推荐</view>
      <scroll-view class="recommend-scroll" scroll-x>
        <view class="recommend-list">
          <view class="recommend-card" wx:for="{{shop.recommendations}}" wx:key="id" bindtap="onTapRecommendation" data-id="{{item.id}}">
            <view class="recommend-cover-wrap">
              <image class="recommend-cover" src="{{item.coverImage}}" mode="aspectFill" />
              <view class="recommend-review-bar">
                <text class="recommend-review-text">{{item.reviewCount || 0}}人测评</text>
              </view>
            </view>
            <view class="recommend-info">
              <text class="recommend-title">{{item.name}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="bottom-actions safe-area-bottom">
      <view class="share-btn" bindtap="onShareTap">
        <text class="share-icon">↗</text>
        <text>分享</text>
      </view>
      <view class="nav-btn" bindtap="onNavigate">导航</view>
    </view>
  </block>
</view>
