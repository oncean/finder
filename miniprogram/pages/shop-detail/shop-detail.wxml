<view class="review-page">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && (shop.id || reviews.length > 0)}}">
    <!-- 顶部返回栏 -->
    <view class="top-nav" style="padding-top: calc({{statusBarHeight}}px + 88rpx)">
      <view class="back-btn" bindtap="onBack"><image class="back-icon" src="/static/icons/return.svg" mode="aspectFit" /></view>
      <text class="nav-title">店铺详情</text>
      <view class="nav-placeholder"></view>
    </view>

    <!-- 店铺信息卡 -->
    <view style="padding: 10rpx 20rpx;">
      <shop-section
      shop="{{shop}}"
      shop-name="{{shop.name}}"
      location="{{shop.city}}"
      summary-tags="{{shop.summaryTags}}"
      comment-avatars="{{shop.commentAvatars}}"
      comment-count="{{shop.commentCount}}"
      show-ai-summary="{{true}}"
      shop-id="{{shop.id}}"
      show-share="{{true}}"
      bind:tapShop="onTapShop"
    />
    </view>

    <!-- 评价列表 -->
    <view class="review-list">
      <view class="review-card" wx:for="{{reviews}}" wx:key="id" bindtap="onTapReview" data-id="{{item.id}}">
        <!-- feed-head -->
        <view class="feed-head">
          <view class="head-main">
            <view class="title-row">
              <image class="author-avatar" src="{{item.author.avatar}}" mode="aspectFill" wx:if="{{item.author.avatar}}" />
              <text class="feed-title text-bold text-ellipsis">{{item.title}}</text>
              <text class="rank-pill" wx:if="{{item.rankText}}">{{item.rankText}}</text>
            </view>
            <view class="title-row">
              <text class="feed-desc text-ellipsis" wx:if="{{item.content}}">{{item.content}}</text>
              <text class="date-text" wx:if="{{item.dateText || item.locationText}}">{{item.dateText}}  {{item.locationText}}</text>
            </view>
          </view>
        </view>

        <!-- image-grid -->
        <view class="image-grid" wx:if="{{item.images.length}}">
          <image class="food-image" src="{{item.images[0]}}" mode="aspectFill" wx:if="{{item.images[0]}}" catchtap="onPreviewImage" data-url="{{item.images[0]}}" data-images="{{item.images}}" />
          <image class="food-image" src="{{item.images[1]}}" mode="aspectFill" wx:if="{{item.images[1]}}" catchtap="onPreviewImage" data-url="{{item.images[1]}}" data-images="{{item.images}}" />
          <view class="receipt-card" wx:if="{{item.images[2]}}">
            <image class="receipt-bg" src="{{item.images[2]}}" mode="aspectFill" catchtap="onPreviewImage" data-url="{{item.images[2]}}" data-images="{{item.images}}" />
            <text class="receipt-amount" wx:if="{{item.amountText}}">-{{item.amountText}}</text>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-reviews" wx:if="{{!reviews.length}}">
        <text class="empty-text">暂无评价</text>
      </view>

      <!-- 加载更多提示 -->
      <view class="load-more" wx:if="{{reviews.length > 0 && !noMore}}">
        <text wx:if="{{loadingMore}}">加载中...</text>
        <text wx:else>上拉加载更多</text>
      </view>

      <!-- 没有更多了 -->
      <view class="no-more" wx:if="{{noMore && reviews.length > 0}}">
        <text>没有更多了</text>
      </view>
    </view>
  </block>
</view>
