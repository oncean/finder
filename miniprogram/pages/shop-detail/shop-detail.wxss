.shop-detail-page {
  background: #f5f5f5;
  min-height: 100vh;
}

.shop-cover-wrapper {
  width: 100%;
  height: 400rpx;
}

.shop-cover {
  width: 100%;
  height: 100%;
}

.shop-info-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.shop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.shop-name {
  font-size: 40rpx;
  flex: 1;
}

.shop-rating {
  display: flex;
  align-items: baseline;
  background: rgba(163, 230, 53, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.rating-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #65a30d;
}

.rating-text {
  font-size: 22rpx;
  color: #65a30d;
  margin-left: 4rpx;
}

.shop-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.category {
  font-size: 26rpx;
  color: #666;
}

.dot {
  margin: 0 12rpx;
  color: #ccc;
}

.review-count {
  font-size: 26rpx;
  color: #999;
}

.shop-address {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.address-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.address-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.navigate-btn {
  background: #a3e635;
  color: #1a1a2e;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.business-hours {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #666;
}

.hours-icon {
  margin-right: 12rpx;
}

.ai-summary-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.reviews-section {
  background: #fff;
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.review-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.reviewer-info {
  flex: 1;
  margin-left: 16rpx;
}

.reviewer-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.review-time {
  font-size: 22rpx;
}

.review-rating {
  font-size: 26rpx;
  color: #f59e0b;
}

.review-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.review-images {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.review-images image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin: 8rpx;
}

.loading-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
