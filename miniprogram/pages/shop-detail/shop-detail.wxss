.review-page {
  background: #f7f7f7;
  min-height: 100vh;
}

/* 顶部返回栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 44rpx 32rpx 16rpx;
  background: #fff;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 44rpx;
  height: 44rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
  flex: 1;
  text-align: center;
}

.nav-placeholder {
  width: 64rpx;
  height: 64rpx;
}

.menu-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.circle-dot {
  font-size: 32rpx;
}

/* 大图 */
.review-hero {
  width: 100%;
  height: 506rpx;
  display: block;
}

/* 评价列表 */
.review-list {
  padding: 0 0 24rpx;
}

.review-card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 34rpx rgba(31, 41, 55, 0.08);
}

/* feed-head */
.feed-head {
  display: flex;
  padding: 19rpx 24rpx 20rpx;
  gap: 14rpx;
}

.author-avatar {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.head-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.title-row-desc{
  padding: 0 12rpx;
}

.feed-title {
  font-size: 31rpx;
  color: #1f2933;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.feed-desc {
  font-size: 23rpx;
  color: #a3a3a3;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 65%;
}

.rank-pill {
  background: linear-gradient(90deg, #dcfce7 0%, #94f2d4 100%);
  color: #196b3f;
  font-size: 21rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  padding: 7rpx 16rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  font-style: italic;
}

.date-text {
  color: #9ca3af;
  font-size: 22rpx;
  width: 30%;
  text-align: right;
}

/* image-grid */
.image-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1.02fr;
  gap: 8rpx;
  padding: 0 30rpx 30rpx;
}

.food-image,
.receipt-card {
  height: 214rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.food-image {
  width: 100%;
}

.receipt-card {
  position: relative;
  background: #f8fff4;
  border: 4rpx solid #ecffd8;
}

.receipt-bg {
  width: 100%;
  height: 100%;
}

.receipt-amount {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  color: #111827;
  font-size: 18rpx;
  font-weight: 800;
}

/* 空状态 */
.empty-reviews {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载更多 */
.load-more,
.no-more {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 40rpx;
}

.load-more text,
.no-more text {
  font-size: 24rpx;
  color: #999;
}
