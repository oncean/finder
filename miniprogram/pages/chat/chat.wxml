<view class="chat-page">
  <tab-header 
    active-tab="chat"
    location="{{groupInfo.district || groupInfo.city || ''}}"
    group-id="{{groupId}}"
  />
  
  <view class="unsupported" wx:if="{{noGroup}}">
    <text>暂未开通该区域</text>
  </view>

  <block wx:if="{{!noGroup}}">
    <scroll-view
      class="message-list"
      scroll-y
      scroll-into-view="{{scrollIntoView}}"
      id="message-list"
      refresher-enabled
      refresher-triggered="{{refreshing}}"
      bindrefresherrefresh="onPullDownRefresh"
    >
      <view class="no-more" wx:if="{{!hasMore && messages.length > 0 && !loading}}">
        <text>已经到顶了</text>
      </view>

      <view class="loading" wx:if="{{loading}}">加载中...</view>

      <block wx:for="{{messages}}" wx:key="id">
        <view id="msg-{{item.id}}">
          <message-item
            message="{{item}}"
            isSelf="{{item.sender.id === userId}}"
            bindtapShop="onTapShopCard"
          />
        </view>
      </block>

      <view class="empty" wx:if="{{messages.length === 0 && !loading}}">
        <text>暂无消息，来说点什么吧~</text>
      </view>
    </scroll-view>

    <chat-input
      bindsend="onSendMessage"
      bindshowAddSheet="onShowAddSheet"
    />

    <add-sheet
      visible="{{showAddSheet}}"
      bindclose="onCloseAddSheet"
      bindselectShop="onSelectShop"
      bindselectPhoto="onSelectPhoto"
    />
  </block>
</view>
