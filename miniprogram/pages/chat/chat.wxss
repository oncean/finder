.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #1a1a2e;
  color: #fff;
}

.location-text {
  font-size: 28rpx;
}

.online-info {
  display: flex;
  align-items: center;
}

.online-dot {
  width: 16rpx;
  height: 16rpx;
  background: #a3e635;
  border-radius: 50%;
  margin-right: 8rpx;
}

.online-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.message-list {
  flex: 1;
  padding: 20rpx 0;
}
