.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50%;
}

.background-img {
  position: absolute;
  height: 100%;
  width: 100%;
  z-index: -1;
}

.logo-img {
  height: 140rpx;
  margin-bottom: 10rpx;
}

.slogan {
  font-size: 30rpx;
  color: #333;
  letter-spacing: 3rpx;
  font-weight: 900;
}

.enter-btn {
  position: absolute;
  bottom: 18%;
  left: 50%;
  transform: translateX(-50%);
  width: 480rpx;
  height: 80rpx;
  background-color: #000;
  color: #84cc16;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.enter-btn::after {
  border: none;
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
}

.login-content {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 60rpx 48rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  background: linear-gradient(180deg, #f0fdf4 0%, #fff 30%);
}

.modal-logo-img {
  height: 71rpx;
  margin-bottom: 20rpx;
  position: abs;
}

.modal-title-section {
  margin-top: 60rpx;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.title-underline {
  width: 120rpx;
  height: 12rpx;
  background: linear-gradient(90deg, #84cc16 0%, #bef264 50%, #d1fae5 100%);
  border-radius: 6rpx;
  margin-top: 8rpx;
}

.user-info-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin-bottom: 32rpx;
  background: transparent;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 24rpx;
  color: #999;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #333;
}

.wechat-login-btn {
  width: 100%;
  height: 110rpx;
  background: #1a1a2e;
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 55rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
  padding: 0;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn[disabled] {
  opacity: 0.5;
}

.wechat-icon-wrapper {
  display: flex;
  align-items: center;
  margin-right: 12rpx;
}

.wechat-icon {
  font-size: 36rpx;
}

.wechat-login-text {
  font-size: 34rpx;
}

.agreement-section {
  display: flex;
  align-items: flex-start;
  padding: 0 10rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #84cc16;
  border-color: #84cc16;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.agreement-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.link {
  color: #84cc16;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #84cc16;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #fff;
}