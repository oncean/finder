<view class="review-page">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && post.id}}">
    <!-- 顶部返回栏 -->
    <view class="top-nav">
      <view class="back-btn" bindtap="onBack">‹</view>
      <text class="nav-title">店铺详情</text>
      <view class="menu-pill">
        <text>•••</text>
        <text class="circle-dot">◎</text>
      </view>
    </view>

    <!-- 大图 -->
    <image class="review-hero" src="{{post.coverImage || post.images[0] || 'http://192.168.2.103/static/review-hero.jpg'}}" mode="aspectFill" />

    <!-- 店铺信息卡 -->
    <view class="shop-card-section" bindtap="onTapShop">
      <view class="shop-card-row">
        <image class="shop-thumb" src="{{post.shop.coverImage || 'http://192.168.2.103/static/review-shop-thumb.jpg'}}" mode="aspectFill" />
        <view class="shop-card-info">
          <text class="shop-card-name text-bold">{{post.shop.name || post.shopName}}</text>
          <text class="shop-card-addr">{{post.shop.address}}</text>
        </view>
        <text class="shop-card-arrow">›</text>
      </view>

      <!-- AI总结标签 -->
      <view class="ai-summary-in-card" wx:if="{{post.shop.summaryTags}}">
        <ai-summary summary="{{post.shop.summaryTags}}" show-title="{{false}}" />
      </view>

      <!-- 测评人数 + 分享 -->
      <view class="reviewer-row">
        <view class="reviewer-avatars">
          <image class="reviewer-avatar" src="{{post.author.avatar || 'http://192.168.2.103/static/review-author.jpg'}}" mode="aspectFill" />
          <image class="reviewer-avatar overlap" src="{{post.author.avatar || 'http://192.168.2.103/static/review-author.jpg'}}" mode="aspectFill" />
          <image class="reviewer-avatar overlap" src="{{post.author.avatar || 'http://192.168.2.103/static/review-author.jpg'}}" mode="aspectFill" />
        </view>
        <text class="reviewer-count">{{post.shop.reviewCount || 2000}}+真实测评过</text>
        <view class="share-btn-small" catchtap="onShareTap">
          <text>分享</text>
        </view>
      </view>
    </view>

    <!-- 评价内容 -->
    <view class="review-content-section">
      <view class="review-author-row">
        <image class="review-author-avatar" src="{{post.author.avatar || 'http://192.168.2.103/static/review-author.jpg'}}" mode="aspectFill" />
        <text class="review-author-name">{{post.author.nickname}}</text>
      </view>
      <text class="review-title text-bold">{{post.title}}</text>
      <text class="review-text">{{post.content}}</text>

      <!-- 三列图片 -->
      <view class="review-images" wx:if="{{post.images && post.images.length > 0}}">
        <image
          wx:for="{{post.images}}"
          wx:key="index"
          class="review-img"
          src="{{item}}"
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-url="{{item}}"
        />
      </view>

      <!-- 日期地点 -->
      <view class="review-meta-row">
        <text class="review-date">{{post.eventDate || '01-24'}}</text>
        <text class="review-location">{{post.eventLocation || '南京'}}</text>
      </view>
    </view>
  </block>
</view>
