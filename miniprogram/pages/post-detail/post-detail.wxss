.review-page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 顶部返回栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(88rpx + env(safe-area-inset-top)) 32rpx 16rpx;
  padding-top: calc(88rpx + constant(safe-area-inset-top));
  background: #fff;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #333;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
}

.menu-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.circle-dot {
  font-size: 32rpx;
}

/* 大图 */
.review-hero {
  width: 100%;
  height: 506rpx;
  display: block;
}

/* 店铺信息卡 */
.shop-card-section {
  background: #fff;
  margin: -40rpx 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
  z-index: 2;
  border: 2rpx solid #c8e64a;
}

.shop-card-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.shop-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.shop-card-info {
  flex: 1;
  min-width: 0;
}

.shop-card-name {
  font-size: 32rpx;
  color: #111;
  display: block;
}

.shop-card-addr {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.shop-card-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.ai-summary-in-card {
  padding: 16rpx 0;
  border-top: 1rpx solid #f3f3f3;
  border-bottom: 1rpx solid #f3f3f3;
  margin-top: 16rpx;
}

/* 测评人数 + 分享 */
.reviewer-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.reviewer-avatars {
  display: flex;
  margin-right: 12rpx;
}

.reviewer-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
}

.reviewer-avatar.overlap {
  margin-left: -16rpx;
}

.reviewer-count {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.share-btn-small {
  background: #111;
  color: #c8e64a;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 评价内容区 */
.review-content-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.review-author-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.review-author-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.review-author-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.review-title {
  font-size: 34rpx;
  color: #111;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.review-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  display: block;
  margin-bottom: 20rpx;
}

/* 三列图片 */
.review-images {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.review-img {
  flex: 1;
  height: 224rpx;
  border-radius: 12rpx;
}

/* 日期地点 */
.review-meta-row {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f3f3;
}

.review-date {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.review-location {
  font-size: 24rpx;
  color: #999;
}
