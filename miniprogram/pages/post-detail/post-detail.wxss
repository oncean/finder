.post-detail-page {
  background: #f5f5f5;
  min-height: 100vh;
}

.image-swiper {
  height: 500rpx;
}

.image-swiper image {
  width: 100%;
  height: 100%;
}

.content-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.post-title {
  font-size: 36rpx;
  margin-bottom: 20rpx;
  display: block;
}

.post-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 24rpx;
  display: block;
}

.author-section {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.author-section .avatar {
  margin-right: 16rpx;
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.post-time {
  font-size: 24rpx;
}

.location-section {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.location-icon {
  margin-right: 8rpx;
}

.shop-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.related-section {
  background: #fff;
  padding: 32rpx;
}

.related-list {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.related-item {
  width: calc(33.33% - 20rpx);
  margin: 10rpx;
}

.related-cover {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}

.related-title {
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
}
