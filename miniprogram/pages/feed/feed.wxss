.feed-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ffffff;
}

.feed-list {
  height: 0;
  flex: 1;
  background: #ffffff;
}

.feed-list .container {
  padding: 0 28rpx 28rpx;
}

.latest-float {
  position: fixed;
  top: 190rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 99;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background: #65a30d;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(101, 163, 13, 0.28);
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}
