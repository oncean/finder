.chat-panel {
  display: flex;
  flex-direction: column;
  height: 100%;
  position: relative;
  overflow: hidden;
}
.header-info-container{
  background: linear-gradient( 145deg, #F1FFD9 0%, #F5F5F5 100%)
}
/* header-info */
.header-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: #ffffff;
  border-radius: 50rpx 50rpx 0 0 ;
  flex-shrink: 0;
}

.location-info {
  display: flex;
  align-items: center;
}

.location-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
}

.location-text {
  font-size: 24rpx;
  color: #333;
  margin-left: 5rpx;
}

.online-info {
  display: flex;
  align-items: center;
}

.online-avatars {
  display: flex;
  margin-right: 12rpx;
}

.avatar-preview {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-right: -25rpx;
  background-color: #fff;
  position: relative;
}

.avatar-preview:first-child {
  z-index: 3;
}

.avatar-preview:nth-child(2) {
  z-index: 2;
}

.avatar-preview:nth-child(3) {
  z-index: 1;
  margin-right: 0;
}

.online-count-wrap {
  padding: 0rpx 20rpx;
  background: #9D9D9D;
  border-radius: 30rpx 30rpx 30rpx 30rpx;
  height: 36rpx;
  line-height: 32rpx;
}

.online-count {
  font-size: 22rpx;
  color: #ffffff;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 0;
  overflow: hidden;
}

.header-info-line{
  width: 80%;
  height: 3rpx;
  background-color: #F0F0F0;
  margin: auto;
}

.loading {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 20rpx 0;
  color: #ccc;
  font-size: 24rpx;
}

/* 新消息浮窗 */
.new-msg-tip {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 180rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.new-msg-tip:active {
  opacity: 0.8;
}

.tip-arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

.chat-input{
  height: 180rpx;
  box-shadow: 0rpx 10rpx 20rpx 1rpx rgba(147,147,147,0.56);
  flex-shrink: 0; /* 防止被压缩 */
}