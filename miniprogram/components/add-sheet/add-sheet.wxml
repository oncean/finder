<view class="add-sheet-mask {{visible ? 'show' : ''}}" bindtap="onClose" wx:if="{{visible}}">
  <view class="add-sheet-content" catchtap="preventBubble">
    <view class="sheet-header">
      <view class="sheet-title">添加内容</view>
      <view class="close-btn" bindtap="onClose">✕</view>
    </view>
    
    <view class="sheet-options">
      <view class="option-item" bindtap="onSelectShop">
        <view class="option-icon shop-icon">🏪</view>
        <text class="option-label">选择店铺</text>
      </view>
      
      <view class="option-item" bindtap="onSelectPhoto">
        <view class="option-icon photo-icon">📷</view>
        <text class="option-label">选择照片</text>
      </view>
    </view>
  </view>
</view>
