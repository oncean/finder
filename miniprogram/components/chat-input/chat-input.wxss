.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.add-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #999;
}

.send-btn {
  margin-left: 16rpx;
  padding: 14rpx 28rpx;
  background: #e0e0e0;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn.active {
  background: #a3e635;
  color: #1a1a2e;
  font-weight: bold;
}
