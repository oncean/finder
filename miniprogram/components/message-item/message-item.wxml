<view class="message-item {{isSelf ? 'self' : ''}}">
  <image wx:if="{{!isSelf && message.sender.avatar}}" class="avatar avatar-small" src="{{message.sender.avatar}}" mode="aspectFill" />
  
  <view class="message-content {{message.type === 'image' ? 'image-message' : ''}}">
    
    <!-- 文字消息 -->
    <view class="bubble text-bubble" wx:if="{{message.type === 'text'}}">
      <text>{{message.content}}</text>
    </view>
    
    <!-- 图片消息 -->
    <view class="bubble image-bubble" wx:if="{{message.type === 'image'}}" bindtap="onPreviewImage">
      <image src="{{message.content}}" mode="widthFix" lazy-load />
    </view>
    
    <!-- 店铺卡片消息 -->
    <view class="bubble shop-bubble" wx:if="{{message.type === 'shop_card' && message.shopCard}}">
      <shop-section
        shop="{{message.shopCard}}"
        shop-name="{{message.shopCard.name}}"
        location="{{message.shopCard.address}}"
        summary-tags="{{message.shopCard.summaryTags}}"
        comment-avatars="{{message.shopCard.commentAvatars}}"
        comment-count="{{message.shopCard.reviewCount || 0}}"
        show-ai-summary="{{message.shopCard.summaryTags ? true : false}}"
        shop-id="{{message.shopCard.shopId || message.shopId}}"
        bindtapShop="onTapShopCard"
      />
    </view>
    
    <text class="message-time" wx:if="{{message.type !== 'shop_card'}}">{{displayTime}}</text>
  </view>
</view>
