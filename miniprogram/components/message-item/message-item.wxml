<view class="message-item {{isSelf ? 'self' : ''}}">
  <image class="avatar avatar-small" src="{{message.sender.avatar || 'http://192.168.2.103/static/default-avatar.png'}}" mode="aspectFill" />
  
  <view class="message-content">
    <text class="sender-name text-muted">{{message.sender.nickname}}</text>
    
    <!-- 文字消息 -->
    <view class="bubble text-bubble" wx:if="{{message.type === 'text'}}">
      <text>{{message.content}}</text>
    </view>
    
    <!-- 图片消息 -->
    <view class="bubble image-bubble" wx:if="{{message.type === 'image'}}" bindtap="onPreviewImage">
      <image src="{{message.content}}" mode="widthFix" lazy-load />
    </view>
    
    <!-- 店铺卡片消息 -->
    <view class="bubble shop-bubble" wx:if="{{message.type === 'shop_card'}}" bindtap="onTapShopCard">
      <view class="shop-card-top">
        <image class="shop-logo" src="{{message.shopCard.logo || message.shopCard.coverImage || 'http://192.168.2.103/static/default-shop.png'}}" mode="aspectFill" />
        <view class="shop-info">
          <view class="shop-name-row">
            <text class="shop-name text-bold">{{message.shopCard.name}}</text>
            <view class="rank-badge" wx:if="{{message.shopCard.summaryTags}}">
              <text>推荐榜第一</text>
            </view>
          </view>
          <view class="shop-address-row">
            <image class="pin-icon" src="/static/icons/dingwei.svg" mode="aspectFit" />
            <text class="shop-address text-muted">{{message.shopCard.address}}</text>
            <text class="nav-text">导航</text>
          </view>
        </view>
      </view>
      
      <view class="shop-summary" wx:if="{{message.shopCard.summaryTags}}">
        <ai-summary
          summary="{{message.shopCard.summaryTags}}"
          author-avatar="{{message.shopCard.logo || message.sender.avatar || 'http://192.168.2.103/static/default-avatar.png'}}"
          tester-count="{{message.shopCard.reviewCount || 100}}+"
          show-footer="{{true}}"
          show-view="{{true}}"
        />
      </view>
    </view>
    
    <text class="message-time">{{formatTime(message.createdAt)}}</text>
  </view>
</view>
