.feed-card {
  background: #fff;
  border-radius: 34rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 34rpx rgba(31, 41, 55, 0.08);
}

.feed-head {
  display: flex;
  justify-content: space-between;
  padding: 30rpx 30rpx 18rpx;
  gap: 18rpx;
}

.author-row {
  display: flex;
  min-width: 0;
  flex: 1;
}

.author-avatar {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.title-wrap {
  min-width: 0;
  flex: 1;
}

.feed-title {
  display: block;
  font-size: 31rpx;
  color: #1f2933;
  line-height: 1.25;
  margin-bottom: 8rpx;
}

.feed-desc {
  display: block;
  font-size: 23rpx;
  color: #a3a3a3;
  line-height: 1.3;
}

.right-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.rank-pill {
  background: linear-gradient(90deg, #dcfce7 0%, #94f2d4 100%);
  color: #196b3f;
  font-size: 21rpx;
  font-weight: 700;
  padding: 7rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
}

.date-text {
  color: #9ca3af;
  font-size: 22rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1.02fr;
  gap: 8rpx;
  padding: 0 30rpx;
}

.food-image,
.receipt-card {
  height: 214rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.food-image {
  width: 100%;
}

.receipt-card {
  position: relative;
  background: #f8fff4;
  border: 4rpx solid #ecffd8;
}

.receipt-bg {
  width: 100%;
  height: 100%;
}

.receipt-amount {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  color: #111827;
  font-size: 18rpx;
  font-weight: 800;
}

.shop-section {
  margin: 24rpx 30rpx 30rpx;
  padding: 22rpx 24rpx 24rpx;
  border: 2rpx solid #d8f99b;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff 0%, #fbfff6 100%);
}

.shop-top {
  display: flex;
  align-items: center;
}

.shop-thumb {
  width: 68rpx;
  height: 68rpx;
  border-radius: 8rpx;
  margin-right: 14rpx;
}

.shop-main {
  min-width: 0;
  flex: 1;
}

.shop-name {
  display: block;
  color: #1f2933;
  font-size: 29rpx;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.shop-location {
  display: flex;
  align-items: center;
  color: #9ca3af;
  font-size: 24rpx;
}

.pin {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.nav-text {
  color: #9bd625;
  font-weight: 700;
  margin-left: 4rpx;
}

.ai-summary-wrap {
  margin-top: 24rpx;
}
