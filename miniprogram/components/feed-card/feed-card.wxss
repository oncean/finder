.feed-card {
  background: #fff;
  border-radius: 34rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.feed-head {
  display: flex;
  padding: 30rpx 20rpx 18rpx;
  gap: 14rpx;
}

.author-avatar {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.head-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feed-title {

  font-family: PingFang SC, PingFang SC;
  font-weight: 800;
  font-size: 30rpx;
  height: 42rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.feed-desc {
  font-family: PingFang SC, PingFang SC;
  font-weight: 400;
  font-size: 24rpx;
  color: #a3a3a3;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 65%;
}

.rank-pill {
  color: #196b3f;
  font-size: 21rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  padding: 7rpx 16rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  font-style: italic;
}

.date-text {
  color: #9ca3af;
  font-size: 22rpx;
  width: 30%;
  text-align: right;
}

.image-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1.02fr;
  gap: 8rpx;
  padding: 0 20rpx;
}

.food-image,
.receipt-card {
  height: 210rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.food-image {
  width: 210rpx;
  height: 210rpx;
}

.receipt-card {
  position: relative;
  background: #f8fff4;
  border: 4rpx solid #ecffd8;
}

.receipt-bg {
  width: 100%;
  height: 100%;
}

.receipt-amount {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  color: #111827;
  font-size: 18rpx;
  font-weight: 800;
}


