<view class="feed-card" bindtap="onTap">
  <view class="feed-head">
    <view class="head-main">
      <view class="title-row">
      
        <image class="author-avatar" src="{{post.author.avatar}}" mode="aspectFill" wx:if="{{post.author.avatar}}" />
        <text class="feed-title text-bold text-ellipsis">{{post.title}}</text>
        <text class="rank-pill" wx:if="{{rankText}}">{{rankText}}</text>
      </view>
      <view class="title-row">
        <text class="feed-desc text-ellipsis" wx:if="{{post.content}}">{{post.content}}</text>
      <text class="date-text" wx:if="{{dateText || locationText}}">{{dateText}}  {{locationText}}</text>
      </view>
    </view>
  </view>

  <view class="image-grid" wx:if="{{post.images.length || post.coverImage}}">
    <image class="food-image" src="{{post.images[0] || post.coverImage}}" mode="aspectFill" wx:if="{{post.images[0] || post.coverImage}}" />
    <image class="food-image" src="{{post.images[1] || post.coverImage}}" mode="aspectFill" wx:if="{{post.images[1] || post.coverImage}}" />
    <view class="receipt-card" wx:if="{{post.images[2]}}">
      <image class="receipt-bg" src="{{post.images[2]}}" mode="aspectFill" />
      <text class="receipt-amount" wx:if="{{amountText}}">-{{amountText}}</text>
    </view>
  </view>

  <shop-section
    wx:if="{{post.shopName}}"
    shop="{{post.shop}}"
    shop-name="{{post.shopName}}"
    location="{{post.city}}"
    summary-tags="{{post.shop.summaryTags}}"
    author-avatar="{{post.author.avatar}}"
    tester-count-text="{{testerCountText}}"
    show-ai-summary="{{true}}"
    shop-id="{{post.shopId}}"
    bind:tapShop="onTapShop"
  />
</view>
