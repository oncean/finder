.consume-record {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 16rpx 0;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-label {
  font-size: 24rpx;
  color: #999;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.record-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.merchant-name {
  font-size: 26rpx;
  color: #666;
}

.trade-time {
  font-size: 22rpx;
}
