.ai-summary {
  padding: 24rpx 22rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient( 90deg, #F2FFF0 0%, #FFFFFF 100%);
}

.summary-title {
  display: inline-block;
  color: #111827;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 900;
  font-style: italic;
  margin-bottom: 24rpx;
  position: relative;
}

.summary-title::after {
  content: '';
  position: absolute;
  right: -24rpx;
  top: 4rpx;
  width: 24rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #ffd86b;
}

.summary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 18rpx;
}

.summary-tag {
  display: flex;
  align-items: center;
  font-weight: 500;
  font-size: 24rpx;
  color: #222222;
  white-space: nowrap;
}

.tag-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  margin-right: 8rpx;
}

.back-icon{
  height: 30rpx;
  width: 30rpx;
  margin-right: 10rpx;
}

.positive .tag-icon {
  background: #a3e635;
}

.negative .tag-icon {
  background: #ef4444;
}


