.ai-summary {
  padding: 8rpx 0;
}

.summary-header {
  margin-bottom: 12rpx;
}

.cost {
  font-size: 28rpx;
  font-weight: bold;
  color: #f59e0b;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-positive {
  background: rgba(163, 230, 53, 0.15);
  color: #65a30d;
}

.tag-negative {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.tag-icon {
  margin-right: 6rpx;
  font-weight: bold;
  font-size: 20rpx;
}
